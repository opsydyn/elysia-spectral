{
  "openapi": "3.0.3",
  "info": {
    "title": "elysia-spectral dev app",
    "description": "Development documentation",
    "version": "0.1.0"
  },
  "tags": [
    {
      "name": "Users",
      "description": "User operations"
    }
  ],
  "paths": {
    "/": {
      "get": {
        "summary": "Show dev endpoints",
        "description": "Return the local endpoints exposed by the dev fixture app.",
        "operationId": "getDevEndpoints",
        "tags": [
          "Users"
        ],
        "responses": {
          "200": {
            "description": "Response for status 200",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": [
                    "service",
                    "openapi",
                    "spec",
                    "healthcheck"
                  ],
                  "properties": {
                    "service": {
                      "type": "string"
                    },
                    "openapi": {
                      "type": "string"
                    },
                    "spec": {
                      "type": "string"
                    },
                    "healthcheck": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/users": {
      "get": {
        "summary": "List users",
        "description": "Return all users from the dev fixture endpoint.",
        "operationId": "listUsers",
        "tags": [
          "Users"
        ],
        "responses": {
          "200": {
            "description": "Response for status 200",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": [
                      "id",
                      "name"
                    ],
                    "properties": {
                      "id": {
                        "type": "string"
                      },
                      "name": {
                        "type": "string"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {}
  }
}
